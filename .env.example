# Configuración de conexión con Interactive Brokers
IBKR_HOST=127.0.0.1
IBKR_PORT=4002

# Nota: El client_id real se genera dinámicamente en tiempo de ejecución (random.randint)
# para evitar colisiones y el error de "Client ID already in use", por lo que no es necesario configurarlo.

# Nota de Seguridad: Por propósitos de demostración académica, el hash SHA-256
# de la contraseña ('admin2026') está configurado en el código.
